fun main() {

    //4 - Faça um algoritmo que calcule e escreva a média
    // aritmética dos números inteiros entre 15 (inclusive)
    // e 100 (inclusive).

    var contador: Int = 0
    var soma: Int = 0

  for (i in 15..100){
    soma += i
      contador++
  }

    val media = soma.toDouble() / contador
    println("A média dos valores de 15 a 100 é: $media")
}

