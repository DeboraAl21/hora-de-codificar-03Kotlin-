fun main() {

    // 6 - Escreva um programa para ler 2 notas de um aluno,
    // calcular e imprimir a média final. Considere que a nota
    // de aprovação é 9,5. Logo após escrever a mensagem "Calcular a
    // média de outro aluno Sim/Não?" e solicitar um resposta.
    // Se a resposta for "S", o programa deve ser executado novamente,
    // caso contrário deve ser encerrado exibindo a quantidade de
    // alunos aprovados.



        var aprovados = 0
        var resposta = "S"   // controla o loop

        while (resposta == "S" || resposta == "s") {

            println("Escreva a primeira nota: ")
            val num1 = readln().toDouble()

            println("Escreva a segunda nota: ")
            val num2 = readln().toDouble()

            val media = (num1 + num2) / 2

            if (media >= 9.5) {
                println("O aluno foi aprovado! A média dele é: $media")
                aprovados++
            } else {
                println("O aluno foi reprovado! A média dele é: $media")
            }

            println(
                "Calcular a média de outro aluno?\n" +
                        "(S) Sim\n" +
                        "(N) Não"
            )

            // ATUALIZA A MESMA VARIÁVEL USADA NO WHILE
            resposta = readln()
        }

        println("Programa encerrado. Total de alunos aprovados: $aprovados")
    }
